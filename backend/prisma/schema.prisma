// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(cuid())
  clerkId String @unique
  
  role Role @default(USER)


  // relations 
  subscription Subscription?

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  applications Application[]

  interview Interview[]

  interviewSession InterviewSession[]

  preperationSession PreparationSession[]
}

model Subscription{
  id String @id @default(cuid())
  userId String @unique
  credits Int @default(0)
  plan Plan @default(FREE)
  user User @relation(fields: [userId],references: [id])
}

enum Role{
  USER
  RECRUITER
}

enum Plan{
  FREE
  PRO
  PREMIUM
}


model Application{
  id String @id @default(uuid())
  userId String 
  user          User        @relation(fields: [userId], references: [id])
  company String
  role String
  link String
  source String
  status ApplicationStatus @default(APPLIED)
  appliedAt DateTime @default(now())
  updatedAt     DateTime   @updatedAt
  location String 
  salary String

  notes Note[]
}

model Note{
  id String @id @default(uuid())
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  applicationId String 

  content String

  createdAt DateTime @default(now())

}

enum ApplicationStatus{
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  OFFER
}


model Interview {
  id              String   @id @default(uuid())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  domain          String
  role            String
  experience      Int

  durationMinutes Int
  interviewType   String

  
  codingEnabled   Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        InterviewSession[]
}



model InterviewSession {
  id          String @id @default(uuid())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  interviewId  String
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  attempt     Int @default(1)

  status      String

  createdAt   DateTime @default(now())
  endedAt     DateTime?
  difficulty  String
  questions   SessionQuestion[]

  results InterviewSessionResult[]
}

model SessionQuestion {
  id            String @id @default(uuid())

  sessionId     String
  session       InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type          String

  question      String

  // THEORY
  answer        String?

 

 

  userAnswer    String?
  isCorrect     Boolean?

  order Int

  createdAt     DateTime @default(now())
}


model InterviewSessionResult {
  id          String @id @default(cuid())

  sessionId   String @unique
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  score       Int        // 0 - 100
  rating      String     // "Poor", "Average", "Good", "Excellent"

  correctCount Int
  totalCount   Int

  feedback    String     // overall AI summary

  strengths   String?
  weaknesses  String?

  timeTaken   Int?       // seconds

  createdAt   DateTime @default(now())
}



model PreparationSession {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role String
  experience Int
  description String

  topics Topic[]
  questions PreparationQuestion[]

  createdAt DateTime @default(now())
}

model Topic {
  id String @id @default(uuid())

  name String

  sessionId String
  session PreparationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model PreparationQuestion {
  id String @id @default(uuid())

  question String
  answer String?
  note String?
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())

  explaination String
  sessionId String
  session PreparationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}